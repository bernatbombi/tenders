meta {
  name: Analyse tender
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/tenders/{{expediente}}/analyze
  body: none
  auth: bearer
}

params:path {
  expediente: 1579267C
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  const data = res.getBody();
  bru.setVar("jobId", data.jobId);
}
